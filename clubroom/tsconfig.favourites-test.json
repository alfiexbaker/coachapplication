{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".tmp-tests",
    "baseUrl": "./",
    "types": ["node"],
    "lib": ["ES2020"],
    "strict": false,
    "noImplicitAny": false,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "__tests__/favourites/**/*.ts",
    "__tests__/favourites/**/*.tsx"
  ]
}
