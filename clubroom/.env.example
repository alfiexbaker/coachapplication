# =============================================================================
# CLUBROOM ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and configure for your environment.
# All EXPO_PUBLIC_ variables are exposed to the client bundle.
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------

# Environment name: development | staging | production
EXPO_PUBLIC_ENV=development

# Enable debug mode (extra logging, dev tools)
EXPO_PUBLIC_DEBUG=true

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------

# API base URL
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# API timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT=30000

# Use mock data instead of real API (development only)
EXPO_PUBLIC_USE_MOCK=true

# Backend/API marketplace fixture mode (used by scripts/marketplace-seed-kit.mjs)
# Set to 1 to enable generation/validation/write-back, 0 to disable.
API_MARKETPLACE_SEED_ENABLED=0

# API runtime data backend:
# - seed: serve linked marketplace fixture data (current pre-REST mode)
# - db: disable seed-backed endpoints and prepare for repository/database implementation
API_DATA_BACKEND=seed

# Pre-API live mode for app runtime (mock mode only):
# seeds rich relational data globally and emits periodic activity pulses.
EXPO_PUBLIC_PRE_API_LIVE_MODE=true
EXPO_PUBLIC_PRE_API_LIVE_SEED_ON_AUTH=true
EXPO_PUBLIC_PRE_API_LIVE_PULSE_INTERVAL_MS=45000

# Legacy relational seed gate (kept for compatibility with existing seed hooks)
EXPO_PUBLIC_ENABLE_RELATIONAL_DEMO_SEED=true

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Enable/disable features at runtime. Set to 'true' or 'false'.

# Core features
EXPO_PUBLIC_FEATURE_FAMILY_SHARING=true
EXPO_PUBLIC_FEATURE_GROUP_SESSIONS=true
EXPO_PUBLIC_FEATURE_VIDEO_ANALYSIS=true
EXPO_PUBLIC_FEATURE_SKILL_TREE=true

# Payment features
EXPO_PUBLIC_FEATURE_PAYMENTS=false
EXPO_PUBLIC_FEATURE_PACKAGES=true
EXPO_PUBLIC_FEATURE_PROMO_CODES=true

# Social features
EXPO_PUBLIC_FEATURE_CLUB_FEED=true
EXPO_PUBLIC_FEATURE_CHALLENGES=true
EXPO_PUBLIC_FEATURE_LEADERBOARDS=false

# Experimental features (use with caution)
EXPO_PUBLIC_FEATURE_AI_INSIGHTS=false
EXPO_PUBLIC_FEATURE_LIVE_TRACKING=false

# -----------------------------------------------------------------------------
# ANALYTICS & MONITORING
# -----------------------------------------------------------------------------

# Enable analytics tracking
EXPO_PUBLIC_ANALYTICS_ENABLED=false

# Analytics provider (segment | amplitude | mixpanel)
EXPO_PUBLIC_ANALYTICS_PROVIDER=segment

# Segment write key (if using Segment)
EXPO_PUBLIC_SEGMENT_WRITE_KEY=

# Sentry DSN for error tracking
EXPO_PUBLIC_SENTRY_DSN=

# Log level: debug | info | warn | error
EXPO_PUBLIC_LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------

# Auth provider (mock | firebase | auth0 | supabase)
EXPO_PUBLIC_AUTH_PROVIDER=mock

# Session timeout in minutes (0 = no timeout)
EXPO_PUBLIC_SESSION_TIMEOUT=0

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------

# Storage provider (async-storage | mmkv)
EXPO_PUBLIC_STORAGE_PROVIDER=async-storage

# Cache TTL in seconds (0 = no cache)
EXPO_PUBLIC_CACHE_TTL=300

# -----------------------------------------------------------------------------
# NOTIFICATIONS
# -----------------------------------------------------------------------------

# Push notification provider (expo | firebase | onesignal)
EXPO_PUBLIC_PUSH_PROVIDER=expo

# Default quiet hours (24h format)
EXPO_PUBLIC_QUIET_HOURS_START=22:00
EXPO_PUBLIC_QUIET_HOURS_END=07:00

# -----------------------------------------------------------------------------
# MAPS & LOCATION
# -----------------------------------------------------------------------------

# Google Maps API key (for coach discovery map)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Default search radius in miles
EXPO_PUBLIC_DEFAULT_SEARCH_RADIUS=10

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Max API requests per minute
EXPO_PUBLIC_RATE_LIMIT_RPM=60

# Max booking requests per hour (prevent spam)
EXPO_PUBLIC_BOOKING_RATE_LIMIT=10

# -----------------------------------------------------------------------------
# UI CONFIGURATION
# -----------------------------------------------------------------------------

# Enable haptic feedback
EXPO_PUBLIC_HAPTICS_ENABLED=true

# Animation speed multiplier (1 = normal, 0 = disabled)
EXPO_PUBLIC_ANIMATION_SCALE=1

# Default currency
EXPO_PUBLIC_DEFAULT_CURRENCY=GBP

# Default locale
EXPO_PUBLIC_DEFAULT_LOCALE=en-GB
