{
  "name": "@clubroom/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "build:release": "npm run build && npm run sentry:sourcemaps",
    "sentry:sourcemaps": "node ./scripts/upload-sourcemaps.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/modules/**/*.test.ts"
  },
  "dependencies": {
    "@clubroom/config": "workspace:*",
    "@clubroom/db": "workspace:*",
    "@clubroom/shared-contracts": "workspace:*",
    "@sentry/node": "^10.48.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
