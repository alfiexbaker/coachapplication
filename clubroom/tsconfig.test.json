    "__tests__/invoices/**/*.tsx",
    "__tests__/safety/**/*.ts",
    "__tests__/safety/**/*.tsx",
    "__tests__/analytics/**/*.ts",
    "__tests__/analytics/**/*.tsx",
    "__tests__/consent/**/*.ts",
    "__tests__/consent/**/*.tsx",
    "__tests__/discover/**/*.ts",
    "__tests__/discover/**/*.tsx",
    "__tests__/compare/**/*.ts",
    "__tests__/compare/**/*.tsx",
