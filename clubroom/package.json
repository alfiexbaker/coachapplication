{
  "name": "clubroom",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 expo start",
    "start": "NODE_OPTIONS=--max-old-space-size=8192 expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "NODE_OPTIONS=--max-old-space-size=8192 expo start --web",
    "web:mobile:open": "node ./scripts/open-mobile-web.mjs",
    "lint": "expo lint",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 tsc -p tsconfig.typecheck.json",
    "test:compile": "rm -rf .tmp-tests && tsc -p tsconfig.test.json",
    "test:snapshots": "npm run test:compile && node --require ./scripts/test-register.js --test .tmp-tests/__tests__/book-coach.snapshot.js",
    "test:favourites": "rm -rf .tmp-tests && tsc -p tsconfig.favourites-test.json && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/favourites/*.js\"",
    "test:referrals": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/referrals/*.js\"",
    "test:drills": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/drills/*.js\"",
    "test:goals": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/goals/*.js\"",
    "test:invoices": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/invoices/*.js\"",
    "test:safety": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/safety/*.js\"",
    "test:analytics": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/analytics/*.js\"",
    "test:consent": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/consent/*.js\"",
    "test:discover": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/discover/*.js\"",
    "test:calendar": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/calendar/*.js\"",
    "test:compare": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/compare/*.js\"",
    "test:skills": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/skills/*.js\"",
    "test:video": "npm run test:compile && node --require ./scripts/test-register.js --test \".tmp-tests/__tests__/video/*.js\"",
    "test:bookings": "npm run test:compile && node --require ./scripts/test-register.js --test .tmp-tests/__tests__/bookings/booking-service.test.js",
    "test:messaging": "npm run test:compile && node --require ./scripts/test-register.js --test .tmp-tests/__tests__/messaging/messaging-service.test.js",
    "test:family": "npm run test:compile && node --require ./scripts/test-register.js --test .tmp-tests/__tests__/family/*.test.js",
    "test": "npm run test:snapshots",
    "format:check": "prettier --check 'app/**/*.tsx' 'components/**/*.tsx' 'services/**/*.ts' 'hooks/**/*.ts'",
    "lint:ui-actions": "node ./scripts/lint-ui-actions.js",
    "audit:ui": "node ./scripts/audit-ui.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-calendar": "~15.0.8",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.10",
    "expo-document-picker": "^14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-map-clustering": "^4.0.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.6",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
