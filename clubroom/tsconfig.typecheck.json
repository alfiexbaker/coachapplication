{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "services/**/*.ts",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "constants/**/*.ts",
    "contracts/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "navigation/**/*.ts"
  ],
  "exclude": ["node_modules", ".tmp-tests"]
}
